# Copy to .env and fill in real values locally. NEVER commit .env or paste
# real keys into chat/tickets/PRs — use this file (with placeholders) for
# anything you share or hand off.

# --- App / DB ---
APP_ENV=development
DATABASE_URL=sqlite:///./waqf_docverify.db
# postgresql+psycopg2://waqf:waqf@localhost:5432/waqf_docverify

# --- Auth ---
JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Sarvam Vision (Primary OCR) ---
SARVAM_API_KEY=
SARVAM_API_BASE_URL=https://api.sarvam.ai

# --- Gemini Vision (Fallback OCR, replaces GPT-4o mini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Extra retry attempts on a 429 (rate limit), and the minimum gap enforced
# between consecutive Gemini calls from this process — raise the interval
# if you're still seeing 429s on a free-tier key.
GEMINI_MAX_RETRIES=2
GEMINI_MIN_CALL_INTERVAL_SECONDS=4.5

# --- Shasan-SLM extraction-assist (Pod B) ---
SHASAN_SLM_API_URL=
SHASAN_SLM_API_KEY=

# --- AWS S3 (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=waqf-docverify-scans
AWS_S3_REGION=ap-south-1

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
